                                <div class="text-center">
                                    <?php if($dataDetail->dokumen){ ?>
                                        <img class="img-fluid px-3 px-sm-4 mt-3 mb-4" style="width: 25rem;" src="<?php echo base_url().'files/infaqMasuk/'.$dataDetail->dokumen; ?>">
                                    <?php }else{ ?>
                                        <img class="img-fluid px-3 px-sm-4 mt-3 mb-4" style="width: 25rem;" src="<?php echo base_url(); ?>assets/sb2/img/undraw_posting_photo.svg">
                                    <?php } ?>
                                   
                                </div>
                                <h6 class="m-0 font-weight-bold text-primary"> Jenis Penyaluran : <?php echo $dataDetail->keterangan . ' (' .$dataDetail->satuan.')'; ?></h6><hr/>
                                <table class="table table-striped table-bordered">
                                    <tr>
                                        <td>Total penyaluran</td><td class="text-center"><?php echo number_format($dataDetail->amount,0,',','.') . ' ' . $dataDetail->satuan; ?> </td>
                                    </tr>
                                    <tr>
                                        <td>Belum Didaftarkan</td><td class="text-center" id='sisaPemakaian'></td>
                                    </tr>
