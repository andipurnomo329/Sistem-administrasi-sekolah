<script>
$(document).ready(function() {
    var sisa = 0;
    $('#infoProses').hide();
    var anggaran = <?php echo $dataDetail->amount; ?>;
    var table = $('#myTable').DataTable({
        "processing": true,
        "serverSide": true,
        "ajax": {
            "url": "<?php echo base_url('transaksiDetail/getDataDetailTansaksi') ?>",
            "type": "POST",
            "data": function(d) {
                d.transaksiId = <?php echo $dataDetail->id; ?> //mambahkan parameter tambahan
            }
        },
        "searchDelay": 500,
        "columns": [
            {
                "data": null,
                "render": function (data, type, row, meta) {
                    return meta.row + meta.settings._iDisplayStart + 1;
                },
                "className": 'text-center',
                "width": "5%"
            },
            { "data": "title" },
            { "data": "peopleCode" },
            { "data": "amount" },
            { "data": "updatedDtm","width": "15%" },
            {
                "data": null,
                "className": 'text-center',
                "render": function (data, type, row) {
                    // let total = total + row.amount;
                    // console.log(row);
                    submitAmount = row.amount;
                    if(row.isSuccess == 0){
                        warna = 'danger';
                        isSuccessUpdate = 1;
                    }else{
                        warna = 'success';
                        isSuccessUpdate = 0;
                    }

                    return '<button class="btn btn-'+warna+' btn-edit btn-sm" data-id="'+row.id+'" data-isSuccess="'+isSuccessUpdate+'"><i class="fas fa-check"></i></button> ' +
                           '<button class="btn btn-danger btn-delete btn-sm" data-id="'+row.id+'"><i class="fas fa-trash"></i></button> ';
                }
            }
        ]
    });

    table.on('draw', function() {
        // This will be called every time the table is redrawn
        $.ajax({
            url: '<?php echo base_url('transaksiDetail/getTotalAmountByHeaderId') ?>',
            type: 'POST',
            data: {transaksiId: <?php echo $dataDetail->id; ?>},
            success: function(response) {
                var totalAmount = JSON.parse(response);
                console.log(totalAmount);
                sisa = anggaran - totalAmount.amount;
                belumDisalurkan = totalAmount.amount - totalAmount.amountIsActive;
                $('#amount').val(submitAmount);
                $('#amount').attr({"max" : sisa});
                $('#sisaPemakaian').html( convertToRupiah(sisa) +' <?php echo $dataDetail->satuan; ?>');
                $('#totalPemakaian').html(convertToRupiah(totalAmount.amount) +' <?php echo $dataDetail->satuan; ?>');
                $('#totalPenerimaan').html(convertToRupiah(totalAmount.amountIsActive) +' <?php echo $dataDetail->satuan; ?>');
                $('#belumDisalurkan').html(convertToRupiah(belumDisalurkan) +' <?php echo $dataDetail->satuan; ?>');
            }
        });
        
    });

    $('#myTable_filter input').unbind().bind('input', function(e) {
        var value = $(this).val();
        if (value.length >= 3) {
            table.search(value).draw();
        } else {
            table.search('').draw();
        }
    });

    $('#myTable tbody').on('click', '.btn-edit', function () {
        var id = $(this).data('id');
        var isSuccess = $(this).data('issuccess');
        console.log(isSuccess);
        $.ajax({
            url: '<?php echo base_url('transaksiDetail/flagStatusPenerimaan') ?>',
            type: 'POST',
            data: {id: id, isSuccess : isSuccess},
            success: function(response) {
                var data = JSON.parse(response);
                // console.log(data);
                if(data.status){
                    $('#myTable').DataTable().ajax.reload();
                }
               
            }
        });
    });

    $('#myTable tbody').on('click', '.btn-delete', function () {
        var id = $(this).data('id');
        if (confirm("Are you sure !") == true) {
            $.ajax({
                url: '<?php echo base_url('transaksiDetail/deleteData') ?>',
                type: 'POST',
                data: {id: id},
                success: function(response) {
                    var data = JSON.parse(response);
                    if(data.status){
                        $('#myTable').DataTable().ajax.reload();
                    }
                }
            });
        } else {
            alert('cancel Delete ID: ' + id);
            
        }
        // Tambahkan logika untuk menghapus data
    });

    $('#tombolTambah').on('click',function () {
        // console.log(sisa);
        if(sisa > 0){
            $('#inputData').modal('show');
        }else{
            alert('dana tidak cukup');
        }
    });

    $('#searchButton').on('click',function () {
        $('#SearchData').modal('show');
        $('#myTable2').removeAttr('style');
    });

    $('#amount').on('change',function () {
        inputAmount = $('#amount').val();
    });

    var table2 = $('#myTable2').DataTable({
        "processing": true,
        "serverSide": true,
        "ajax": {
            "url": "<?php echo base_url('people/getData') ?>",
            "type": "POST",
            "data": function(d) {
                d.type = 2, d.subType = '> 0';  // Menambahkan parameter tambahan
            }
        },
        "searchDelay": 500,
        "columns": [
            {
                "data": null,
                "orderable": false,
                "searchable": false,
                "render": function (data, type, row) {
                    var checked = selectedIds.some(item => item.id == row.id)  ? 'checked' : ''; // Cek apakah ID sudah dipilih
                    return '<input type="checkbox" class="row-select" value="' + row.id + '" ' + checked + '>';
                }
            },
            {
                "data": null,
                "render": function (data, type, row, meta) {
                    return meta.row + meta.settings._iDisplayStart + 1;
                },
                "width": "4%"
            },
            { "data": "nama" },
            { "data": "id" },
            { "data": "nik" },
            {
                "data": null,
                "render": function (data, type, row) {
                    return row.jenis_kelamin === 'P' ? 'Laki-Laki' : 'Perempuan';
                }
            },
            { "data": "tempat_lahir" },
            { "data": "tanggal_lahir" }
        ]
    });

    // Event handler untuk select-all checkbox
    $('#select-all').on('click', function () {
        var rows = table2.rows({ 'search': 'applied' }).nodes();
        $('input[type="checkbox"]', rows).prop('checked', this.checked);

        // Tambahkan atau hapus semua ID tergantung dari status checkbox "select-all"
        if (this.checked) {
            // Tambah semua ID dari halaman saat ini ke selectedIds jika tidak ada di dalamnya
            table2.rows({ 'search': 'applied' }).data().each(function (data) {
                // console.log(data);
                if (!selectedIds.includes( {id: data.id,nama: data.nama} )) {
                    selectedIds.push({id: data.id,nama: data.nama});
                }
            });
        } else {
            // Hapus semua ID dari halaman saat ini dari selectedIds
            table2.rows({ 'search': 'applied' }).data().each(function (data) {
                var index = selectedIds.indexOf(data.id);
                if (index == -1) {
                    selectedIds.splice(index, 1);
                }
            });
        }
        console.log(selectedIds);
    });

    // Event handler untuk perubahan checkbox individual
    $('#myTable2 tbody').on('change', '.row-select', function () {
        var id = $(this).val();
        var nama = $(this).closest('tr').find('td:eq(2)').text(); 

        if (this.checked) {
            if (!selectedIds.includes(id)) {
                selectedIds.push({id: id,nama: nama }); // Tambahkan ID ke array jika tidak ada
            }
        } else {
            var index = selectedIds.indexOf(id);
            if (index == -1) {
                selectedIds.splice(index, 1); // Hapus ID dari array jika ada
            }
        }
        $('#title').val(selectedIds.length+' Orang');
        console.log('Selected IDs: ', selectedIds); // Cetak semua ID yang dipilih
    });

    $('#searchButton').on('click', function () {
        $('#SearchData').modal('show');
        $('#myTable2').removeAttr('style');
    });

    var selectedIds = [];

    $('#sendSelectedIds').on('click', function () {
        if (selectedIds.length === 0) {
            alert("Tidak ada data yang dipilih.");
            return;
        }

        var transaksiId = '<?php echo $dataDetail->id; ?>'; // Ambil nilai nominal dari input atau elemen lain
        var amount = $('#amount').val(); 
        $.ajax({
            url: '<?php echo base_url('transaksiDetail/addNonTunaiRegist'); ?>', // Ganti dengan controller dan method yang sesuai
            type: 'POST',
            data: { 
                selectedIds: selectedIds, 
                isCash: 1, 
                amount: amount, 
                transaksiId: transaksiId // Menambahkan parameter nominal
            },
            success: function(response) {
                var data = JSON.parse(response);
                if(data==null){
                    $('#peopleId').val(peopleIds);
                    $('#title').val(namas);
                    $('#SearchData').modal('hide');
                }else{
                    $('#alertTab2').html('Data '+ data.title +' Sudah pernah diinput !');
                    $('#alertTab2').attr({"class" : 'text-danger'});
                    alert('Data '+ data.title +' Sudah pernah diinput !');
                }
            }
        });
    });

});
</script>